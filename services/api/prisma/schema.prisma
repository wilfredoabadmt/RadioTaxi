generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                Int                @id @default(autoincrement())
  name              String
  createdAt         DateTime           @default(now())

  tripRequests      TripRequest[]
  pricingRules      PricingRule[]
  geofences         Geofence[]
  complianceRecords ComplianceRecord[]
  corporateReports  CorporateReport[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER") // USER | DRIVER | ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver        Driver?
  tripRequests  TripRequest[] @relation("CustomerTrips")
}

model Driver {
  id        Int   @id @default(autoincrement())
  userId    Int   @unique
  user      User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  vehicle  Vehicle[]
  trips     Trip[]
  tripRequests TripRequest[]

  complianceRecords ComplianceRecord[]
}

model Vehicle {
  id        Int     @id @default(autoincrement())
  plate     String  @unique
  driverId  Int?
  driver    Driver? @relation(fields: [driverId], references: [id])

  createdAt DateTime @default(now())

  trips Trip[]
}

model TripRequest {
  id                 Int       @id @default(autoincrement())

  // 👤 RELACIONES
  customerId         Int
  customer           User      @relation("CustomerTrips", fields: [customerId], references: [id])

  companyId          Int?
  company            Company?  @relation(fields: [companyId], references: [id])

  driverId           Int?
  driver             Driver?   @relation(fields: [driverId], references: [id])

  // 📍 UBICACIÓN
  originAddress      String?
  originLat          Float?
  originLng          Float?

  destinationAddress String?
  destinationLat     Float?
  destinationLng     Float?

  // ⏱ TIEMPOS
  requestedAt        DateTime  @default(now())
  scheduledAt        DateTime?
  acceptedAt         DateTime?
  completedAt        DateTime?

  status             String    @default("PENDING") // PENDING | ACCEPTED | COMPLETED | CANCELLED

  trip               Trip?

  @@index([customerId])
  @@index([companyId])
  @@index([driverId])
}

model Trip {
  id            Int         @id @default(autoincrement())

  tripRequestId Int         @unique
  tripRequest   TripRequest @relation(fields: [tripRequestId], references: [id])

  driverId      Int
  driver        Driver      @relation(fields: [driverId], references: [id])

  vehicleId     Int
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id])

  fareTotal     Float       @default(0)

  startedAt     DateTime    @default(now())
  completedAt   DateTime?

  status        String      @default("COMPLETED")

  fares         TripFare[]

  @@index([driverId])
}

model TripFare {
  id              Int         @id @default(autoincrement())

  tripId          Int
  trip            Trip        @relation(fields: [tripId], references: [id])

  pricingRuleId   Int
  pricingRule     PricingRule @relation(fields: [pricingRuleId], references: [id])

  baseFare        Float       @default(0)
  distanceMeters  Int         @default(0)
  durationSeconds Int         @default(0)
  totalFare       Float       @default(0)

  createdAt       DateTime    @default(now())
}

model PricingRule {
  id             Int        @id @default(autoincrement())

  companyId      Int
  company        Company    @relation(fields: [companyId], references: [id])

  type           String     @default("STANDARD")

  baseFare       Float      @default(0)
  kmRate         Float      @default(0)
  minuteRate     Float      @default(0)
  minFare        Float      @default(0)

  tollSurcharge  Float      @default(0)
  peakMultiplier Float      @default(1.0)

  areaGeoJson    String?

  tripFares      TripFare[]
}

model Geofence {
  id          Int     @id @default(autoincrement())

  companyId   Int
  company     Company @relation(fields: [companyId], references: [id])

  name        String?
  type        String  @default("ZONE")
  surcharge   String  @default("0")

  areaGeoJson String? @db.Text
}

model ComplianceRecord {
  id        Int     @id @default(autoincrement())

  driverId  Int
  driver    Driver  @relation(fields: [driverId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

model CorporateReport {
  id         Int      @id @default(autoincrement())

  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])

  title      String
  reportType String
  data       Json?

  createdAt  DateTime @default(now())

  @@index([companyId])
}
